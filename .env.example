# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# FRED (Federal Reserve macro data: rates, inflation, labor, growth). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: a custom OpenAI-compatible endpoint (vLLM, LM Studio, llama.cpp,
# relay). Select provider "openai_compatible" and set the base URL; the key is
# optional (local servers need none).
#OPENAI_COMPATIBLE_API_KEY=

# AWS Bedrock (provider "bedrock", install with: pip install ".[bedrock]").
# Auth uses the standard AWS credential chain; set the region (and optionally a
# named profile). No single API key.
#AWS_DEFAULT_REGION=us-west-2
#AWS_PROFILE=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
# NOTE: set this > 0 if you enable PM self-consistency below, or the samples
# collapse to one identical run.
#TRADINGAGENTS_TEMPERATURE=0.4

# ── Forecasting desk: self-consistency · quant brain · fusion ────────────────
# Portfolio-Manager self-consistency: sample the final forecast N times and
# aggregate (majority direction, median price, confidence = agreement fraction).
# 1 = off. Needs TEMPERATURE > 0. Cost = N x the final step only, not the graph.
#TRADINGAGENTS_PM_SAMPLES=1

# Quant brain + fusion (opt-in). 1 turns on the whole combined pipeline:
# gradient-boosted per-horizon P(up) on Binance 5m data, injected into the
# debate AND fused with the agents' call into the final forecast, with a
# Quant/Desk/Fused side-by-side and 3-way scoring in `score`. Adds a Binance
# fetch + model training (cached). Install once: pip install ".[quant]".
#TRADINGAGENTS_QUANT_ENABLED=0
# Weight on the quant model when fusing with the agents (1.0 = quant-only,
# 0.0 = agents-only). 0.6 favours the quant — the side with the measured edge.
#TRADINGAGENTS_QUANT_FUSION_WEIGHT=0.6
# 5m bars to train the quant models on (50000 ≈ 174 days; 150000 ≈ 1.4 yr,
# which gave every horizon a positive edge in testing).
#TRADINGAGENTS_QUANT_TOTAL_BARS=50000
# Reuse the persisted quant models this many hours before retraining.
#TRADINGAGENTS_QUANT_RETRAIN_HOURS=6

# Kronos (opt-in): a zero-shot generative foundation model used as a SECOND
# directional prior, fused like the quant brain. Heavy — install once:
# pip install ".[kronos]" (torch etc.; downloads ~100MB from HuggingFace on first
# use). 1 turns it on.
#TRADINGAGENTS_KRONOS_ENABLED=0
# Weight on Kronos when fusing with the agents (1.0 = Kronos-only, 0.0 = agents).
#TRADINGAGENTS_KRONOS_FUSION_WEIGHT=0.6
# Price paths sampled per forecast (more = smoother P(up) but slower on CPU).
#TRADINGAGENTS_KRONOS_SAMPLES=30
# Recent 5m bars fed to Kronos (<= the model's 512-bar context).
#TRADINGAGENTS_KRONOS_LOOKBACK=512
# Model id + device (cpu / cuda:0). Kronos-small ~100MB, CPU-friendly.
#TRADINGAGENTS_KRONOS_MODEL=NeoQuasar/Kronos-small
#TRADINGAGENTS_KRONOS_DEVICE=cpu

# Flat-band at the 5m reference horizon, as a fraction of price (0.001 = 0.1%);
# the scorer scales it by sqrt(time) across horizons. Raise to label more small
# moves "Flat"; lower to grade direction more strictly.
#TRADINGAGENTS_FORECAST_DEADBAND_BASE=0.001
